<odoo>
    <record id="view_hr_past_work_tree" model="ir.ui.view">
        <field name="name">hr.past.work.list</field>
        <field name="model">hr.past.work</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="company_name"/>
                <field name="designation"/>
                <field name="organization"/>
                <field name="date_joining"/>
                <field name="date_relieving"/>
            </list>
        </field>
    </record>

    <record id="view_employee_form_inherit_past_work" model="ir.ui.view">
        <field name="name">hr.employee.form.past.work</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Past Work Profile">
                    <field name="past_work_ids"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
