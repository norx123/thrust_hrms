<odoo>
    <record id="view_employee_sign_template_form" model="ir.ui.view">
        <field name="name">employee.sign.template.form</field>
        <field name="model">employee.sign.template</field>
        <field name="arch" type="xml">
            <form string="Sign Template">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="document" filename="document_name"/>
                        <field name="document_name"/>
                        <field name="employee_id"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_sign_template_list" model="ir.ui.view">
        <field name="name">employee.sign.template.list</field>
        <field name="model">employee.sign.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="action_employee_sign_template" model="ir.actions.act_window">
        <field name="name">Sign Templates</field>
        <field name="res_model">employee.sign.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>