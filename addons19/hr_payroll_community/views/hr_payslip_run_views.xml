<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Search views -->
    <record id="hr_payslip_run_search" model="ir.ui.view">
        <field name="name">hr.payslip.run.search</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <search string="Search Payslip Batches">
                <field name="name" string="Payslip Batches"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <filter string="Draft"   name="draft"   domain="[('state','=','draft')]"/>
                <filter string="Waiting" name="verify"  domain="[('state','=','verify')]"/>
                <filter string="Done"    name="done"    domain="[('state','=','done')]"/>
                <filter string="Done"    name="done_filter" domain="[('state','in',('done','close'))]"/>
                <filter string="Paid"    name="paid"    domain="[('state','=','paid')]"/>
            </search>
        </field>
    </record>

    <!-- List views -->
    <record id="hr_payslip_run_view_tree" model="ir.ui.view">
        <field name="name">hr.payslip.run.view.list</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <list string="Payslip Batches"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'verify'"
                  decoration-success="state in ('done','paid')"
                  decoration-muted="state == 'close'">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="credit_note"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'verify'"
                       decoration-success="state in ('done','paid')"
                       decoration-muted="state == 'close'"/>
            </list>
        </field>
    </record>

    <!-- Kanban views -->
    <record id="hr_payslip_run_view_kanban" model="ir.ui.view">
        <field name="name">hr.payslip.run.view.kanban</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_content oe_kanban_global_click">
                            <div class="row">
                                <div class="col-6">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="col-6">
                                    <span class="float-right badge badge-secondary">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="col-12">
                                    <span>
                                        <field name="date_start"/> - <field name="date_end"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form views -->
    <record id="hr_payslip_run_view_form" model="ir.ui.view">
        <field name="name">hr.payslip.run.view.form</field>
        <field name="model">hr.payslip.run</field>
        <field name="arch" type="xml">
            <form string="Payslip Batch">
                <header>
                    <!-- Draft: Generate + Confirm to Waiting -->
                    <button name="%(hr_payslip_by_employees_action)d"
                            type="action"
                            string="Generate Payslips"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_payslip_verify"
                            type="object"
                            string="Confirm"
                            class="btn-secondary"
                            invisible="state != 'draft'"/>

                    <!-- Waiting → Done (Validate + compute all) -->
                    <button name="action_payslip_done"
                            type="object"
                            string="Validate"
                            class="btn-primary"
                            invisible="state != 'verify'"/>

                    <!-- Done → Paid -->
                    <button name="action_payslip_paid"
                            type="object"
                            string="Pay"
                            class="btn-primary"
                            invisible="state != 'done'"/>

                    <!-- Reset to Draft (from Close) -->
                    <button name="action_payslip_run"
                            type="object"
                            string="Set to Draft"
                            invisible="state not in ('close','paid','done')"/>

                    <!-- Close (from Paid) -->
                    <button name="close_payslip_run"
                            type="object"
                            string="Close"
                            invisible="state != 'paid'"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,verify,done,paid"/>
                </header>
                <sheet>
                    <label for="name" class="oe_edit_only"/>
                    <h1>
                        <field name="name" readonly="state != 'draft'"/>
                    </h1>
                    <group col="4">
                        <label for="date_start" string="Period"/>
                        <div>
                            <field name="date_start" class="oe_inline"
                                   readonly="state != 'draft'"/>
                            -
                            <field name="date_end" class="oe_inline"
                                   readonly="state != 'draft'"/>
                        </div>
                        <field name="credit_note" readonly="state != 'draft'"/>
                    </group>
                    <separator string="Payslips"/>
                    <field name="slip_ids" readonly="state != 'draft'">
                        <list string="Payslips">
                            <field name="number" string="Reference"/>
                            <field name="employee_id" string="Employee"/>
                            <field name="name" string="Payslip Name"/>
                            <field name="date_from" string="Date From"/>
                            <field name="date_to" string="Date To"/>
                            <field name="state" string="Status" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-warning="state == 'verify'"
                                   decoration-success="state in ('done','paid')"
                                   decoration-danger="state == 'cancel'"/>
                            <field name="payslip_run_id" string="Payslip Batches"
                                   invisible="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window action -->
    <record id="hr_payslip_run_action" model="ir.actions.act_window">
        <field name="name">Payslips Batches</field>
        <field name="res_model">hr.payslip.run</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="hr_payslip_run_search"/>
    </record>

    <!-- Menu -->
    <menuitem action="hr_payslip_run_action"
              id="menu_hr_payslip_run"
              parent="menu_hr_payroll_community_root"/>
</odoo>
